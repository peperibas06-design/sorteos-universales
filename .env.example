# Copiá este archivo a ".env" y cambiá los valores antes de poner la app en producción.

# Clave usada por Flask para firmar la sesión. Poné cualquier cadena larga y aleatoria.
SECRET_KEY=cambia-esto-por-una-cadena-aleatoria-larga

# Credenciales del panel de administración (/admin/login)
ADMIN_USER=adm
ADMIN_PASSWORD=admin123456789

# Puerto en el que corre la app (opcional, por defecto 5000)
PORT=5000
